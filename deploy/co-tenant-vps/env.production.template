# Island Haven — production .env (co-tenant VPS). Copy to
# /var/www/island-haven/app/artifacts/api-server/.env, fill REAL values, chmod 600.
# NEVER reuse any NasToNas secret. NEVER commit this file with real values.

NODE_ENV=production

# Chosen isolated port (confirmed free in pre-flight). Same value in PM2 env.
PORT=3020
# Node serves the built SPA + /api same-origin (set 0 only if nginx serves static).
SERVE_STATIC=1

# The NEW, isolated database + scoped role created in RUNBOOK §3.
# postgres://<ih_haven_app>:<STRONG_PW>@127.0.0.1:5432/ih_haven
DATABASE_URL=postgres://ih_haven_app:REPLACE_WITH_STRONG_DB_PASSWORD@127.0.0.1:5432/ih_haven

# openssl rand -base64 48   → must be >=32 chars AND != ADMIN_PASSWORD (boot enforces this)
SESSION_SECRET=REPLACE_WITH_OPENSSL_RAND_BASE64_48

# Admin login for the Island Haven dashboard (its own creds — not NasToNas's).
ADMIN_USERNAME=REPLACE_ADMIN_USERNAME
ADMIN_PASSWORD=REPLACE_WITH_STRONG_ADMIN_PASSWORD

# Canonical public origin (drives absolute links, CORS, cookies).
FRONTEND_URL=https://islandhavengsza.com

# Transactional email (optional but recommended). Leave blank to disable email.
RESEND_API_KEY=
EMAIL_FROM=Island Haven <no-reply@islandhavengsza.com>

# REDIS_URL — leave UNSET on a single box. The app falls back to in-memory/inline
# (no external dependency). Only set it if you run a dedicated Redis for IH.
# REDIS_URL=
