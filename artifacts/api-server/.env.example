PORT=3001
DATABASE_URL=postgresql://USER@localhost/ih_haven_dev
ADMIN_USERNAME=your_admin_username   # optional; if set, login requires this username + password
ADMIN_PASSWORD=your_admin_password_here
SESSION_SECRET=your_secret_key_here
NODE_ENV=development

# URL of the frontend, used to build password-reset links
FRONTEND_URL=http://localhost:5173

# Email delivery (Resend). If RESEND_API_KEY is unset, emails are logged to the
# console instead of being sent — fine for local dev.
RESEND_API_KEY=
EMAIL_FROM=Island Haven <onboarding@resend.dev>

# Optional: shared rate-limit store across instances (falls back to in-memory if unset/unreachable)
REDIS_URL=
