# ─── Island Haven — environment template ─────────────────────────────────────
# Copy to `.env` and fill in REAL values. NEVER commit the real .env.
# The api-server REFUSES to boot in production without a valid SESSION_SECRET.

# ── Required ─────────────────────────────────────────────────────────────────
NODE_ENV=production                 # `development` locally
PORT=3001

# Postgres. Point at PgBouncer (port 6432) if you use it — see deploy/pgbouncer.ini.
DATABASE_URL=postgres://ih:CHANGE_ME@127.0.0.1:5432/ih_haven

# HMAC signing key for session cookies. MUST be >=32 chars AND different from
# ADMIN_PASSWORD. Generate: `openssl rand -base64 48`
SESSION_SECRET=CHANGE_ME_min_32_chars_random_and_distinct

# Admin login (single shared admin identity).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_strong_password

# Verifiable Honesty — Ed25519 seed that signs the public "signed numbers" (/verify).
# REQUIRED in production: the server fails loudly at boot without it and /readyz
# gates on it. Generate a fresh 32-byte seed (keep it secret, never commit):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Only the PUBLIC half is ever exposed (auto-derived, served at /.well-known/ih-pubkey).
IH_ATTEST_PRIVATE_KEY_HEX=CHANGE_ME_64_hex_chars_32_byte_seed

# Public site URL (used in emails / password-reset links).
FRONTEND_URL=https://islandhaven.ps

# ── Frontend serving (single-process deploy) ─────────────────────────────────
# In production the api-server serves the built SPA itself (one process = API +
# site). Default static path is ../ih-haven/dist/public relative to CWD; override
# for containers. Set SERVE_STATIC=0 if nginx/CDN serves the frontend instead.
# CLIENT_DIR=/app/artifacts/ih-haven/dist/public
# SERVE_STATIC=1

# ── Email (Resend) — optional; without it, emails are logged, not sent ────────
RESEND_API_KEY=
EMAIL_FROM=Island Haven <onboarding@resend.dev>
# CONTACT_TO=team@islandhaven.ps

# ── Redis — optional; enables shared cache + BullMQ queues + multi-instance ───
# Without it the app is single-instance (in-memory cache, inline jobs). REQUIRED
# if you run more than one api instance. See deploy/SCALING.md.
# REDIS_URL=redis://127.0.0.1:6379

# ── Background worker / scheduler ────────────────────────────────────────────
# Single box: run the worker inside the api process:
# RUN_WORKER_IN_PROCESS=1
# Production (recommended): leave the above unset, run `node dist/worker.mjs`
# separately, and register the daily digest on the worker side:
# ENABLE_DAILY_DIGEST_CRON=1

# ── Tuning (optional; sane defaults in code) ─────────────────────────────────
# PUBLIC_CACHE_MAX_AGE=60          # Cache-Control max-age for anon public GETs
# DB_POOL_MAX=10                   # app-side pool cap (keep low behind PgBouncer)
# QUEUE_ATTEMPTS=5                 # job retry attempts
# QUEUE_BACKOFF_MS=1000            # job retry backoff base
# RATE_LIMIT_GENERAL_MAX=          # raise only for load testing
